---
import { APP_URL, SITE } from "../consts";
---

<header
  class="sticky top-0 z-30 border-b border-base-700/60 bg-base-950/85 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5"
    aria-label="Primary"
  >
    <a href="/" class="group flex items-baseline gap-1 text-base font-bold tracking-tight text-base-100">
      <span class="text-term-400" aria-hidden="true">~/</span>{SITE.name}
      <span class="cursor-blink -mb-px inline-block h-4 w-2 self-center bg-term-400" aria-hidden="true"></span>
    </a>

    <div class="flex items-center gap-2 text-sm sm:gap-4">
      <a
        href="#features"
        class="hidden px-2 py-1.5 text-base-300 transition hover:text-base-100 sm:block"
      >
        --features
      </a>
      <a
        href={`${APP_URL}/`}
        class="px-2 py-1.5 text-base-300 transition hover:text-base-100"
      >
        sign in
      </a>
      <a
        href={`${APP_URL}/`}
        class="rounded-md border border-term-500/60 bg-term-500/10 px-3.5 py-1.5 font-semibold text-term-300 transition hover:bg-term-500/20 hover:shadow-[0_0_18px_rgba(47,213,102,0.25)]"
      >
        $ get-started
      </a>
    </div>
  </nav>
</header>
