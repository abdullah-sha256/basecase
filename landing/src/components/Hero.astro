---
import { APP_URL } from "../consts";
---

<section class="relative overflow-hidden">
  <!-- soft radial glow -->
  <div
    class="pointer-events-none absolute inset-x-0 top-[-10rem] -z-10 mx-auto h-[30rem] max-w-4xl rounded-full bg-brand-400/20 blur-3xl dark:bg-brand-500/10"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 py-24 text-center sm:py-32">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-600 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
      LeetCode interview prep
    </span>

    <h1
      class="mx-auto mt-6 max-w-3xl text-4xl font-bold tracking-tight text-balance sm:text-6xl"
    >
      Cover your bases.
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 text-pretty dark:text-slate-300"
    >
      basecase builds you a personalized LeetCode plan, schedules problems with
      spaced repetition, and tracks every attempt — so you walk into your
      interview ready, not rattled.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={`${APP_URL}/`}
        class="w-full rounded-xl bg-brand-600 px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-700 sm:w-auto"
      >
        Start practicing
      </a>
      <a
        href="#features"
        class="w-full rounded-xl border border-slate-300 px-6 py-3 text-base font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto"
      >
        See how it works
      </a>
    </div>
  </div>
</section>
