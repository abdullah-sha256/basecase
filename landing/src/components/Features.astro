---
const features = [
  {
    file: "plan.config",
    title: "A plan built from your diff",
    body: "basecase profiles your strengths and weaknesses across 18 core patterns — arrays to advanced graphs — and generates a study plan that targets the gaps instead of grinding a generic list.",
    accent: "text-glow-400",
  },
  {
    file: "schedule.cron",
    title: "Beat the forgetting curve",
    body: "Solved isn't remembered. Problems resurface on a spaced-repetition schedule tuned to Ebbinghaus's forgetting curve, resurfacing each concept right before your brain would evict it.",
    accent: "text-term-400",
  },
  {
    file: "progress.log",
    title: "Logs, or it didn't happen",
    body: "Every attempt is recorded — duration, score, tries until solved. Watch your coverage climb pattern by pattern and walk into interview day knowing exactly what you know.",
    accent: "text-amber-400",
  },
];
---

<section id="features" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-sm font-semibold text-term-400">// features</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-base-100 sm:text-4xl">
      Grind smarter, not longer.
    </h2>
    <p class="mt-4 font-sans text-lg text-base-300">
      Brute-forcing 2,000 problems is O(n!) on your sanity. basecase is the
      optimized approach.
    </p>
  </div>

  <div class="mt-14 grid gap-6 lg:grid-cols-3">
    {
      features.map((feature) => (
        <article class="overflow-hidden rounded-xl border border-base-700 bg-base-900/70 transition hover:-translate-y-1 hover:border-base-400 hover:shadow-glow-cyan-md">
          <div class="flex items-center gap-2 border-b border-base-700/70 bg-base-800/60 px-5 py-2.5 text-xs text-base-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 6l-5 6 5 6M16 6l5 6-5 6" />
            </svg>
            <span class={feature.accent}>{feature.file}</span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-base-100">{feature.title}</h3>
            <p class="mt-3 font-sans text-[15px] leading-relaxed text-base-300">{feature.body}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>
