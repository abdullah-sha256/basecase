---
const features = [
  {
    title: "A plan built around you",
    body: "Answer a few questions and basecase maps your strengths and gaps across the core patterns, then builds a study plan that targets what you actually need to work on.",
    icon: "target",
  },
  {
    title: "Remember what you solve",
    body: "Problems resurface on a spaced-repetition schedule based on the forgetting curve, so concepts move into long-term memory instead of fading a day later.",
    icon: "repeat",
  },
  {
    title: "See yourself improve",
    body: "Every attempt is logged — time, score, and pattern — so you can watch your coverage grow and know exactly where you stand before the real thing.",
    icon: "chart",
  },
];
---

<section id="features" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">We make it easy.</h2>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
      Our features are backed by science and designed to make your LeetCode grind
      far more effective.
    </p>
  </div>

  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((feature) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-8 transition hover:border-brand-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
            {feature.icon === "target" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none" />
              </svg>
            )}
            {feature.icon === "repeat" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 9a7 7 0 0 1 12-4.9L19 7M20 15a7 7 0 0 1-12 4.9L5 17" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 3v4h-4M5 21v-4h4" />
              </svg>
            )}
            {feature.icon === "chart" && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 20V10M10 20V4M16 20v-6M22 20H2" />
              </svg>
            )}
          </div>
          <h3 class="mt-6 text-lg font-semibold">{feature.title}</h3>
          <p class="mt-3 text-slate-600 dark:text-slate-300">{feature.body}</p>
        </article>
      ))
    }
  </div>
</section>
