---
import { APP_URL } from "../consts";
---

<section class="mx-auto max-w-6xl px-6 pb-24">
  <div
    class="relative overflow-hidden rounded-3xl bg-brand-600 px-8 py-16 text-center text-white sm:px-16"
  >
    <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
      Your next interview starts with the fundamentals.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-brand-50">
      Build your plan, put in the reps, and track the climb. It's free to start.
    </p>
    <a
      href={`${APP_URL}/`}
      class="mt-8 inline-block rounded-xl bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm transition hover:bg-brand-50"
    >
      Start practicing
    </a>
  </div>
</section>
